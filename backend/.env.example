# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/user-data-manager?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRATION=7d

# Encryption Configuration (AES-256)
ENCRYPTION_KEY=32-character-hex-string-for-aes256-encryption-key
ENCRYPTION_IV=16-character-hex-string-for-aes256-iv

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=15

# Email Configuration (Optional - for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
